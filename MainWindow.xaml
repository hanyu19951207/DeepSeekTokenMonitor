<Window x:Class="DeepSeekTokenMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek Token Monitor"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="40"
        Height="420"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ══ 极光白主题色 ══ -->
        <SolidColorBrush x:Key="PrimaryText" Color="#1E293B"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#0891B2"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#D97706"/>
        <SolidColorBrush x:Key="DangerRed" Color="#DC2626"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#16A34A"/>

        <!-- 按钮通用样式 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ═══════════════════════════════════════════════ -->
        <!-- 收起态：仅显示侧边触发条 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border x:Name="CollapsedStrip"
                Width="32" Height="120"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,140,4,0"
                CornerRadius="8,0,0,8"
                Cursor="Hand">
            <Border.Background>
                <SolidColorBrush Color="#EEF2F7" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🐋" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="CollapsedBalance"
                           Text="¥--"
                           Foreground="#0891B2"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <Ellipse x:Name="CollapsedStatusDot"
                         Width="6" Height="6"
                         Fill="#16A34A"
                         HorizontalAlignment="Center"
                         Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- 展开态：完整面板 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border x:Name="ExpandedPanel"
                CornerRadius="12,0,0,12"
                Margin="0,0,0,0"
                Opacity="0"
                Visibility="Collapsed">
            <Border.Background>
                <SolidColorBrush Color="#F8FAFC"/>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#E2E8F0"/>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1,1,0,1</Thickness>
            </Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect Color="#94A3B8" BlurRadius="16" ShadowDepth="3" Opacity="0.25"/>
            </Border.Effect>

            <Grid Margin="16,20,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 标题行 -->
                    <RowDefinition Height="Auto"/>   <!-- 余额 -->
                    <RowDefinition Height="Auto"/>   <!-- 累计消耗 -->
                    <RowDefinition Height="16"/>     <!-- 间距 -->
                    <RowDefinition Height="Auto"/>   <!-- 今日消耗 -->
                    <RowDefinition Height="Auto"/>   <!-- 本周消耗 -->
                    <RowDefinition Height="Auto"/>   <!-- 本月消耗 -->
                    <RowDefinition Height="16"/>     <!-- 间距 -->
                    <RowDefinition Height="Auto"/>   <!-- 趋势图 -->
                    <RowDefinition Height="Auto"/>   <!-- 预估天数 -->
                    <RowDefinition Height="*"/>      <!-- 弹性空间 -->
                    <RowDefinition Height="Auto"/>   <!-- 底部工具栏 -->
                </Grid.RowDefinitions>

                <!-- ── Row 0: 标题 + 状态 ── -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="StatusDot"
                             Grid.Column="0"
                             Width="8" Height="8"
                             Fill="{StaticResource SuccessGreen}"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>

                    <TextBlock Grid.Column="1"
                               Text="DeepSeek"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="UpdateTimeText"
                               Grid.Column="2"
                               Text="--:--"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- ── Row 1: 余额（大字体） ── -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="可用余额"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="11"/>
                    <TextBlock x:Name="BalanceValue"
                               Text="¥ --"
                               Foreground="{StaticResource AccentCyan}"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,2,0,0"/>
                    <TextBlock x:Name="LowBalanceWarning"
                               Text="⚠ 余额不足"
                               Foreground="{StaticResource DangerRed}"
                               FontSize="11"
                               Visibility="Collapsed"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- ── Row 2: 累计消耗 ── -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="累计消耗"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TotalSpentValue"
                               Grid.Column="1"
                               Text="¥0.00"
                               Foreground="{StaticResource AccentOrange}"
                               FontSize="16"
                               FontWeight="Bold"/>
                </Grid>

                <!-- 分隔线 -->
                <Border Grid.Row="3"
                        Height="1"
                        Background="#E2E8F0"
                        VerticalAlignment="Bottom"/>

                <!-- ── Row 4: 今日消耗 ── -->
                <Grid Grid.Row="4" Margin="0,8,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="今日消耗"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TodayValue"
                               Grid.Column="1"
                               Text="¥0.00"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </Grid>

                <!-- ── Row 5: 本周消耗 ── -->
                <Grid Grid.Row="5" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="本周消耗"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="WeekValue"
                               Grid.Column="1"
                               Text="¥0.00"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </Grid>

                <!-- ── Row 6: 本月消耗 ── -->
                <Grid Grid.Row="6" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="本月消耗"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="MonthValue"
                               Grid.Column="1"
                               Text="¥0.00"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </Grid>

                <!-- ── Row 8: 7日趋势迷你图 ── -->
                <StackPanel Grid.Row="8" Margin="0,4,0,0">
                    <TextBlock Text="7日消耗趋势"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <Border Height="60"
                            Background="#F1F5F9"
                            CornerRadius="6">
                        <Canvas x:Name="TrendChart"
                                ClipToBounds="True"
                                Margin="4"/>
                    </Border>
                </StackPanel>

                <!-- ── Row 9: 预估可用天数 ── -->
                <Grid Grid.Row="9" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="预估可用"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="EstDaysValue"
                               Grid.Column="1"
                               Text="-- 天"
                               Foreground="{StaticResource AccentOrange}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </Grid>

                <!-- ── Row 11: 底部工具栏 ── -->
                <StackPanel Grid.Row="11"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">

                    <Button x:Name="RefreshButton"
                            Style="{StaticResource IconButton}"
                            Content="🔄"
                            ToolTip="立即刷新"
                            Click="RefreshButton_Click"
                            Margin="0,0,12,0"/>

                    <Button x:Name="SettingsButton"
                            Style="{StaticResource IconButton}"
                            Content="⚙"
                            ToolTip="设置"
                            Click="SettingsButton_Click"
                            Margin="0,0,12,0"/>

                    <Button Style="{StaticResource IconButton}"
                            Content="✕"
                            ToolTip="最小化到托盘"
                            Click="MinimizeButton_Click"/>
                </StackPanel>

                <!-- 加载指示器 -->
                <TextBlock x:Name="LoadingIndicator"
                           Grid.Row="11"
                           Text="刷新中..."
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- 错误提示 -->
                <TextBlock x:Name="ErrorText"
                           Grid.Row="11"
                           Text=""
                           Foreground="{StaticResource DangerRed}"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
