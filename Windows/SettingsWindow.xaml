<Window x:Class="DeepSeekTokenMonitor.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeepSeek Token Monitor - 设置"
        Width="380" Height="490"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Window.Background>
        <SolidColorBrush Color="#F8FAFC"/>
    </Window.Background>

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="⚙ 设置"
                   Foreground="#1E293B"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <!-- API Key -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="API Key"
                       Foreground="#64748B" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="ApiKeyBox"
                     Background="#FFFFFF"
                     Foreground="#1E293B"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1"
                     Padding="8,6"
                     FontSize="13"
                     FontFamily="Consolas"/>
        </StackPanel>

        <!-- API 基地址 -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="API 基地址（如使用第三方中转请修改）"
                       Foreground="#64748B" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="BaseUrlBox"
                     Background="#FFFFFF"
                     Foreground="#1E293B"
                     BorderBrush="#CBD5E1"
                     BorderThickness="1"
                     Padding="8,6"
                     FontSize="13"
                     FontFamily="Consolas"/>
        </StackPanel>

        <!-- 轮询间隔 -->
        <StackPanel Grid.Row="6">
            <TextBlock Foreground="#64748B" FontSize="12" Margin="0,0,0,6">
                <Run Text="刷新间隔："/>
                <Run x:Name="IntervalLabel" Text="5" Foreground="#0891B2"/>
                <Run Text=" 分钟"/>
            </TextBlock>
            <Slider x:Name="IntervalSlider"
                    Minimum="1" Maximum="30"
                    Value="5"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    ValueChanged="IntervalSlider_ValueChanged"/>
        </StackPanel>

        <!-- 侧边栏位置 -->
        <StackPanel Grid.Row="8">
            <TextBlock Text="侧边栏位置"
                       Foreground="#64748B" FontSize="12" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RightRadio"
                             Content="屏幕右侧"
                             Foreground="#1E293B"
                             IsChecked="True"
                             Margin="0,0,20,0"/>
                <RadioButton x:Name="LeftRadio"
                             Content="屏幕左侧"
                             Foreground="#1E293B"/>
            </StackPanel>
        </StackPanel>

        <!-- 开机自启动 -->
        <StackPanel Grid.Row="12">
            <CheckBox x:Name="AutoStartCheck"
                      Content="开机自动启动"
                      Foreground="{DynamicResource SettingsFg}"
                      FontSize="13"
                      VerticalContentAlignment="Center"/>
            <TextBlock Text="登录后自动在系统托盘启动，不弹出窗口"
                       Foreground="{DynamicResource SettingsHint}" FontSize="11" Margin="20,4,0,0"/>
        </StackPanel>

        <!-- 主题 -->
        <StackPanel Grid.Row="10">
            <TextBlock Text="主题配色"
                       Foreground="{DynamicResource SettingsLabel}" FontSize="12" Margin="0,0,0,6"/>
            <ComboBox x:Name="ThemeCombo"
                      Background="{DynamicResource SettingsInputBg}"
                      Foreground="{DynamicResource SettingsFg}"
                      BorderBrush="{DynamicResource SettingsInputBorder}"
                      Padding="8,6"
                      FontSize="13">
                <ComboBoxItem Content="极光白（浅色）" Tag="Light"/>
                <ComboBoxItem Content="深空蓝（深色）" Tag="Dark"/>
            </ComboBox>
        </StackPanel>

        <!-- 按钮 -->
        <StackPanel Grid.Row="14"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="TestButton"
                    Content="测试连接"
                    Background="#FFFFFF"
                    Foreground="#0891B2"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Padding="14,8"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="TestButton_Click"/>
            <Button Content="取消"
                    Background="Transparent"
                    Foreground="#64748B"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Padding="14,8"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>
            <Button Content="保存"
                    Background="#0891B2"
                    Foreground="#FFFFFF"
                    BorderThickness="0"
                    Padding="14,8"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
